{
  "expo": {
    "name": "OrthoDaily",
    "description": "OrthoDaily",
    "slug": "orthodox-liturgical-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "orthodox-liturgical",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1410"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "church.orthodox.liturgical.dev"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1410"
      },
      "edgeToEdgeEnabled": true,
      "package": "church.orthodox.liturgical.dev"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "OrthoDaily",
      "shortName": "OrthoDaily",
      "description": "OrthoDaily",
      "title": "OrthoDaily"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "baseUrl": "/orthodox-liturgical-app"
    }
  }
}
